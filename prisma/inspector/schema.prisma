generator client {
  provider = "prisma-client"
  output   = env("PRISMA_CLIENT_OUTPUT") // e.g., "generated/prisma/client"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = env("PRISMA_ZOD_OUTPUT") // e.g., "generated/prisma/zod"
}

datasource db {
  provider = "postgresql"
}

enum ResourceType {
  ARCHIUM
  FAMILY_SEARCH
  WIKIPEDIA
  BABYN_YAR
  WEBSITE
  GOOGLE_DRIVE
}

enum TaskStatus {
  IDLE
  QUEUED
  PROCESSING
  FAILED
  COMPLETED
}

enum Availability {
  PUBLIC
  RESTRICTED
}

model Archive {
  id                     String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code                   String                @db.VarChar(10)
  updated_at             DateTime?             @updatedAt @db.Timestamp(6)
  title                  String?               @db.Text
  info                   String?               @db.Text
  url                    String?               @db.VarChar(255)
  address                String?               @db.VarChar(255)
  phone_number           String?               @db.VarChar(20)
  email                  String?               @db.VarChar(255)
  logo_url               String?               @db.VarChar(255)
  funds                  Fund[]
  family_search_projects FamilySearchProject[]
  daily_stats            DailyStat[]
  sync_tasks             SyncTask[]
  fonds                  Fond[]

  @@index([code])
  @@map("archives")
}

model Fund {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code         String        @db.VarChar(20)
  updated_at   DateTime?     @updatedAt @db.Timestamp(6)
  title        String?       @db.Text
  info         String?       @db.Text
  archive_id   String        @db.Uuid
  archive      Archive       @relation(fields: [archive_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  descriptions Description[]
  years        FundYear[]
  sync_tasks   SyncTask[]

  @@unique([code, archive_id])
  @@index([code])
  @@index([archive_id])
  @@map("funds")
}

model FundYear {
  fund_id    String @db.Uuid
  fund       Fund   @relation(fields: [fund_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  start_year Int
  end_year   Int

  @@id([fund_id, start_year, end_year])
  @@index([start_year, end_year])
  @@map("fund_years")
}

model Description {
  id            String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String                  @db.VarChar(20)
  updated_at    DateTime?               @updatedAt @db.Timestamp(6)
  title         String?                 @db.Text
  info          String?                 @db.Text
  fund_id       String                  @db.Uuid
  fund          Fund                    @relation(fields: [fund_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  cases         Case[]
  years         DescriptionYear[]
  online_copies DescriptionOnlineCopy[]
  sync_tasks    SyncTask[]

  @@unique([code, fund_id])
  @@index([code])
  @@index([fund_id])
  @@map("descriptions")
}

model DescriptionYear {
  description_id String      @db.Uuid
  description    Description @relation(fields: [description_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  start_year     Int
  end_year       Int

  @@id([description_id, start_year, end_year])
  @@index([start_year, end_year])
  @@map("description_years")
}

model DescriptionOnlineCopy {
  updated_at              DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  checked_availability_at DateTime?     @db.Timestamp(6)
  resource_id             String        @db.Uuid
  resource                Resource      @relation(fields: [resource_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  description_id          String        @db.Uuid
  description             Description   @relation(fields: [description_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  url                     String        @db.Text
  availability            Availability?

  @@id([resource_id, description_id, url])
  @@map("description_online_copies")
}

model Case {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String           @db.VarChar(20)
  full_code      String           @default("")
  updated_at     DateTime?        @updatedAt @db.Timestamp(6)
  title          String?          @db.Text
  info           String?          @db.Text
  tags           String[]
  description_id String           @db.Uuid
  description    Description      @relation(fields: [description_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations      CaseLocation[]
  years          CaseYear[]
  authors        CaseAuthor[]
  online_copies  CaseOnlineCopy[]

  @@unique([code, description_id])
  @@index([code])
  @@index([description_id])
  @@index([full_code])
  @@index([full_code(ops: raw("gin_trgm_ops"))], type: Gin, name: "full_code_gin_trgm_ops_idx")
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([info(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([tags], type: Gin)
  @@map("cases")
}

model CaseYear {
  case_id    String @db.Uuid
  case       Case   @relation(fields: [case_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  start_year Int
  end_year   Int

  @@id([case_id, start_year, end_year])
  @@index([start_year, end_year])
  @@map("case_years")
}

model CaseLocation {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lat      Float
  lng      Float
  radius_m Int    @default(0)
  case_id  String @db.Uuid
  case     Case   @relation(fields: [case_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([case_id, lat, lng, radius_m])
  @@map("case_locations")
}

model CaseOnlineCopy {
  updated_at              DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  checked_availability_at DateTime?     @db.Timestamp(6)
  resource_id             String        @db.Uuid
  resource                Resource      @relation(fields: [resource_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  case_id                 String        @db.Uuid
  case                    Case          @relation(fields: [case_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  url                     String        @db.Text
  availability            Availability?

  @@id([resource_id, case_id, url])
  @@index([case_id])
  @@map("case_online_copies")
}

model Author {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  info         String?
  lat          Float?
  lng          Float?
  tags         String[]
  cases        CaseAuthor[]
  file_authors FileAuthor[]

  @@unique([title, lat, lng])
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@map("authors")
}

model CaseAuthor {
  case_id   String @db.Uuid
  author_id String @db.Uuid

  case   Case   @relation(fields: [case_id], references: [id])
  author Author @relation(fields: [author_id], references: [id])

  @@id([case_id, author_id])
  @@index([author_id])
  @@map("case_authors")
}

model Resource {
  id                        String                  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  updated_at                DateTime?               @updatedAt @db.Timestamp(6)
  code                      String                  @db.VarChar(50)
  title                     String?                 @db.Text
  info                      String?                 @db.Text
  url                       String?                 @db.VarChar(255)
  logo_url                  String?                 @db.VarChar(255)
  type                      ResourceType?
  description_online_copies DescriptionOnlineCopy[]
  case_online_copies        CaseOnlineCopy[]
  sync_tasks                SyncTask[]
  inventory_online_copies   InventoryOnlineCopy[]
  file_online_copies        FileOnlineCopy[]

  @@map("resources")
}

model FamilySearchPlace {
  id          Int       @id @db.Integer
  updated_at  DateTime? @updatedAt @db.Timestamp(6)
  title       String?   @db.VarChar(255)
  total_count Int?

  @@map("family_search_places")
}

model FamilySearchProject {
  id         String             @id
  synced_at  DateTime?          @db.Timestamp(6)
  archive_id String?            @db.Uuid
  archive    Archive?           @relation(fields: [archive_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  items      FamilySearchItem[]

  @@map("family_search_projects")
}

model FamilySearchItem {
  id                  String              @id @db.VarChar(50)
  dgs                 String              @db.VarChar(50)
  archival_reference  String?             @db.Text
  volume              String?             @db.Text
  volumes             String?             @db.Text
  date                String?             @db.VarChar(50)
  image_count         Int?                @db.Integer
  project_id          String              @db.VarChar(50)
  project             FamilySearchProject @relation(fields: [project_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  title               String?             @db.Text
  creator             String?             @db.Text
  indexed_child_count Int?                @db.Integer
  updated_at          DateTime            @default(now()) @updatedAt @db.Timestamp(6)
  cataloged_at        DateTime?           @db.Timestamp(6)

  @@map("family_search_items")
}

model DailyStat {
  created_at          DateTime @default(now()) @db.Timestamp(4)
  archive_id          String   @db.Uuid
  archive             Archive  @relation(fields: [archive_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  family_search_count Int      @default(0) @db.Integer
  archium_count       Int      @default(0) @db.Integer
  babyn_yar_count     Int      @default(0) @db.Integer
  wikipedia_count     Int      @default(0) @db.Integer
  google_drive_count  Int      @default(0) @db.Integer
  website_count       Int      @default(0) @db.Integer

  @@id([archive_id, created_at])
  @@map("daily_stats")
}

model SyncTask {
  id             String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  resource_id    String       @db.Uuid
  resource       Resource     @relation(fields: [resource_id], references: [id])
  archive_id     String?      @db.Uuid
  archive        Archive?     @relation(fields: [archive_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fund_id        String?      @db.Uuid
  fund           Fund?        @relation(fields: [fund_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  description_id String?      @db.Uuid
  description    Description? @relation(fields: [description_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  status         TaskStatus   @default(IDLE)
  priority       Int          @default(0)
  api_url        String       @db.Text
  api_params     Json         @db.JsonB
  last_run_at    DateTime?    @db.Timestamp(6)
  next_run_at    DateTime?    @db.Timestamp(6)
  retry_count    Int          @default(0)
  error_log      String?      @db.Text
  fond           Fond?        @relation(fields: [fond_id], references: [id])
  fond_id        String?      @db.Uuid
  inventory      Inventory?   @relation(fields: [inventory_id], references: [id])
  inventory_id   String?      @db.Uuid

  @@unique([resource_id, archive_id, fund_id, description_id, api_params])
  @@map("sync_tasks")
}

// catalog structure

model Fond {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        String      @db.VarChar(20)
  updated_at  DateTime?   @updatedAt @db.Timestamp(6)
  title       String?     @db.Text
  info        String?     @db.Text
  archive_id  String      @db.Uuid
  archive     Archive     @relation(fields: [archive_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  years       FondYear[]
  sync_tasks  SyncTask[]
  inventories Inventory[]

  @@unique([code, archive_id])
  @@index([code])
  @@index([archive_id])
  @@map("fonds")
}

model FondYear {
  fond_id    String @db.Uuid
  fond       Fond   @relation(fields: [fond_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  start_year Int
  end_year   Int

  @@id([fond_id, start_year, end_year])
  @@index([start_year, end_year])
  @@map("fond_years")
}

model Inventory {
  id            String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String                @db.VarChar(20)
  updated_at    DateTime?             @updatedAt @db.Timestamp(6)
  title         String?               @db.Text
  info          String?               @db.Text
  fond_id       String                @db.Uuid
  fond          Fond                  @relation(fields: [fond_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  years         InventoryYear[]
  online_copies InventoryOnlineCopy[]
  sync_tasks    SyncTask[]
  files         File[]

  @@unique([code, fond_id])
  @@index([code])
  @@index([fond_id])
  @@map("inventories")
}

model InventoryYear {
  inventory_id String    @db.Uuid
  inventory    Inventory @relation(fields: [inventory_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  start_year   Int
  end_year     Int

  @@id([inventory_id, start_year, end_year])
  @@index([start_year, end_year])
  @@map("inventory_years")
}

model InventoryOnlineCopy {
  updated_at              DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  checked_availability_at DateTime?     @db.Timestamp(6)
  resource_id             String        @db.Uuid
  resource                Resource      @relation(fields: [resource_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  inventory_id            String        @db.Uuid
  inventory               Inventory     @relation(fields: [inventory_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  url                     String        @db.Text
  availability            Availability?

  @@id([resource_id, inventory_id, url])
  @@map("inventory_online_copies")
}

model File {
  id            String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code          String           @db.VarChar(20)
  full_code     String           @default("")
  updated_at    DateTime?        @updatedAt @db.Timestamp(6)
  title         String?          @db.Text
  info          String?          @db.Text
  tags          String[]
  inventory_id  String           @db.Uuid
  inventory     Inventory        @relation(fields: [inventory_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations     FileLocation[]
  years         FileYear[]
  authors       FileAuthor[]
  online_copies FileOnlineCopy[]

  @@unique([code, inventory_id])
  @@index([code])
  @@index([inventory_id])
  @@index([full_code])
  @@index([full_code(ops: raw("gin_trgm_ops"))], type: Gin, name: "file_full_code_gin_trgm_ops_idx")
  @@index([title(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([info(ops: raw("gin_trgm_ops"))], type: Gin)
  @@index([tags], type: Gin)
  @@map("files")
}

model FileYear {
  file_id    String @db.Uuid
  file       File   @relation(fields: [file_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  start_year Int
  end_year   Int

  @@id([file_id, start_year, end_year])
  @@index([start_year, end_year])
  @@map("file_years")
}

model FileLocation {
  id       String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  lat      Float
  lng      Float
  radius_m Int    @default(0)
  file_id  String @db.Uuid
  file     File   @relation(fields: [file_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([file_id, lat, lng, radius_m])
  @@map("file_locations")
}

model FileOnlineCopy {
  updated_at              DateTime      @default(now()) @updatedAt @db.Timestamp(6)
  checked_availability_at DateTime?     @db.Timestamp(6)
  resource_id             String        @db.Uuid
  resource                Resource      @relation(fields: [resource_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  file_id                 String        @db.Uuid
  file                    File          @relation(fields: [file_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  url                     String        @db.Text
  availability            Availability?

  @@id([resource_id, file_id, url])
  @@index([file_id])
  @@map("file_online_copies")
}

model FileAuthor {
  file_id   String @db.Uuid
  author_id String @db.Uuid

  file   File   @relation(fields: [file_id], references: [id])
  author Author @relation(fields: [author_id], references: [id])

  @@id([file_id, author_id])
  @@index([author_id])
  @@map("file_authors")
}
